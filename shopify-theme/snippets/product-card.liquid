{% if product %}
  {% liquid
    assign first_variant = product.selected_or_first_available_variant
    assign compare_price = first_variant.compare_at_price
    assign product_price = first_variant.price
    assign is_on_sale = false
    if compare_price > product_price
      assign is_on_sale = true
    endif
  %}

  <article class="product-card">
    <a class="product-card__media" href="{{ product.url }}">
      {% if is_on_sale %}
        <span class="product-badge product-badge--sale">Sale</span>
      {% endif %}

      {% if product.featured_image %}
        {{ product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: product.title }}
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </a>

    <div class="product-card__body">
      {% if product.vendor != blank %}
        <div class="product-card__vendor">{{ product.vendor }}</div>
      {% endif %}

      <a class="product-card__title" href="{{ product.url }}">{{ product.title }}</a>

      <div class="product-card__price-wrap">
        <div class="product-card__price">{{ product_price | money }}</div>
        {% if is_on_sale %}
          <div class="product-card__compare">{{ compare_price | money }}</div>
        {% endif %}
      </div>

      <div class="product-card__actions">
        <a class="button button--ghost" href="{{ product.url }}">View details</a>

        {% if product.available %}
          <form method="post" action="{{ routes.cart_add_url }}">
            <input type="hidden" name="id" value="{{ first_variant.id }}">
            <button class="button button--primary" type="submit">Add to cart</button>
          </form>
        {% else %}
          <button class="button button--ghost" type="button" disabled>Sold out</button>
        {% endif %}
      </div>
    </div>
  </article>
{% endif %}
