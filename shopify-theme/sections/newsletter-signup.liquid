{% liquid
  assign subscribe_label = section.settings.button_label | strip | default: 'Subscribe'
%}

<section class="section-shell" id="retention">
  <div class="section-card section-pad">
    <div class="section-head">
      <span class="kicker">{{ section.settings.kicker }}</span>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.description }}</p>
    </div>

    {% form 'customer', class: 'form-shell' %}
      <input type="hidden" name="contact[tags]" value="newsletter">

      <div class="form-row">
        <input
          class="input"
          type="email"
          name="contact[email]"
          id="NewsletterEmail"
          value="{% if customer %}{{ customer.email }}{% endif %}"
          placeholder="Enter your email"
          autocorrect="off"
          autocapitalize="off"
          required
        >
        <button class="button button--primary" type="submit">{{ subscribe_label }}</button>
      </div>

      {% if form.posted_successfully? %}
        <p class="form-note">Thanks! You are subscribed.</p>
      {% endif %}

      {% if form.errors %}
        <p class="form-note">{{ form.errors | default_errors }}</p>
      {% endif %}
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter signup",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Retention"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get launch offers and product drops"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Capture leads for welcome offers, product education, and remarketing flows."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    }
  ],
  "presets": [
    {
      "name": "Newsletter signup"
    }
  ]
}
{% endschema %}
