{% liquid
  assign primary_link = section.settings.primary_link | default: routes.all_products_collection_url
  assign secondary_link = section.settings.secondary_link | default: '/#contact-us'
  assign primary_label = section.settings.primary_label | strip | default: 'Shop now'
  assign secondary_label = section.settings.secondary_label | strip | default: 'Contact us'
  assign external_background_image_url = section.settings.external_background_image_url | strip | default: 'https://picsum.photos/seed/conversion-banner/1800/1000'
%}

<section class="section-shell">
  <div class="cta-banner cta-banner--image">
    <div class="cta-banner__image-wrap">
      {% if section.settings.background_image != blank %}
        {{ section.settings.background_image | image_url: width: 1800 | image_tag: loading: 'lazy', alt: section.settings.heading }}
      {% else %}
        <img src="{{ external_background_image_url | escape }}" alt="{{ section.settings.heading }}" loading="lazy" width="1800" height="1000">
      {% endif %}
    </div>

    <span class="kicker kicker--on-dark">{{ section.settings.kicker }}</span>
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.description }}</p>

    <div class="hero__actions">
      <a class="button button--primary" href="{{ primary_link }}">{{ primary_label }}</a>
      <a class="button button--ghost" href="{{ secondary_link }}">{{ secondary_label }}</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Conversion banner",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Ready to buy"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Start shopping products built for real-world use"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Keep this final CTA section action-oriented with one primary decision path."
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image (optional)"
    },
    {
      "type": "text",
      "id": "external_background_image_url",
      "label": "External background image URL (fallback)",
      "default": "https://picsum.photos/seed/conversion-banner/1800/1000"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Contact us"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Conversion banner"
    }
  ]
}
{% endschema %}
