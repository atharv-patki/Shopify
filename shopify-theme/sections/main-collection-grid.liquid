<section class="section-shell page-hero">
  <div class="section-card section-pad">
    <div class="section-head">
      <span class="kicker">Collection</span>
      <h1>{{ collection.title }}</h1>
      {% if collection.description != blank %}
        <div class="rich-text">{{ collection.description }}</div>
      {% else %}
        <p>Browse products by category and intent.</p>
      {% endif %}
    </div>

    {% if collection.products_count > 0 %}
      {% paginate collection.products by section.settings.products_per_page %}
        <div class="collection-toolbar">
          <p>{{ collection.products_count }} products</p>

          <form method="get" action="{{ collection.url }}">
            <label for="SortBy">Sort by</label>
            <select class="input" name="sort_by" id="SortBy" onchange="this.form.submit()">
              {% assign sort_by = collection.sort_by | default: collection.default_sort_by %}
              {% for option in collection.sort_options %}
                <option value="{{ option.value }}" {% if option.value == sort_by %}selected{% endif %}>
                  {{ option.name }}
                </option>
              {% endfor %}
            </select>
          </form>
        </div>

        <div class="product-grid">
          {% for product in collection.products %}
            {% render 'product-card', product: product %}
          {% endfor %}
        </div>

        {% if paginate.pages > 1 %}
          <nav class="pagination" role="navigation" aria-label="Collection pagination">
            {% if paginate.previous %}
              <a class="pagination__link pagination__link--arrow" href="{{ paginate.previous.url }}">Previous</a>
            {% endif %}

            {% for part in paginate.parts %}
              {% if part.is_link %}
                <a class="pagination__link" href="{{ part.url }}">{{ part.title }}</a>
              {% else %}
                {% if part.title == paginate.current_page %}
                  <span class="pagination__link is-active" aria-current="page">{{ part.title }}</span>
                {% else %}
                  <span class="pagination__ellipsis">{{ part.title }}</span>
                {% endif %}
              {% endif %}
            {% endfor %}

            {% if paginate.next %}
              <a class="pagination__link pagination__link--arrow" href="{{ paginate.next.url }}">Next</a>
            {% endif %}
          </nav>
        {% endif %}
      {% endpaginate %}
    {% else %}
      <div class="empty-state">
        <h3>No products in this collection yet</h3>
        <p>Add products in Shopify Admin and assign them to this collection.</p>
        <a class="button button--primary" href="{{ routes.all_products_collection_url }}">View all products</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Main collection grid",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 24,
      "step": 4,
      "default": 12
    }
  ]
}
{% endschema %}
