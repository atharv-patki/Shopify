{% if section.blocks.size > 0 %}
  <section class="marquee" aria-label="Brand highlights">
    <div class="marquee__track">
      {% for i in (1..2) %}
        {% for block in section.blocks %}
          {% if block.settings.link != blank %}
            <a class="marquee__item marquee__item-link" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>
              {% if block.settings.icon != blank %}
                {{ block.settings.icon | image_url: width: 64 | image_tag: loading: 'lazy', alt: block.settings.label, class: 'marquee__icon' }}
              {% endif %}
              <span>{{ block.settings.label }}</span>
            </a>
          {% else %}
            <span class="marquee__item" {{ block.shopify_attributes }}>
              {% if block.settings.icon != blank %}
                {{ block.settings.icon | image_url: width: 64 | image_tag: loading: 'lazy', alt: block.settings.label, class: 'marquee__icon' }}
              {% endif %}
              <span>{{ block.settings.label }}</span>
            </span>
          {% endif %}
        {% endfor %}
      {% endfor %}
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Brand marquee",
  "blocks": [
    {
      "type": "item",
      "name": "Marquee item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image (optional)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Premium Build"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand marquee",
      "blocks": [
        { "type": "item", "settings": { "label": "Lightning-fast UX" } },
        { "type": "item", "settings": { "label": "Conversion architecture" } },
        { "type": "item", "settings": { "label": "Mobile-first checkout" } },
        { "type": "item", "settings": { "label": "Premium visual language" } },
        { "type": "item", "settings": { "label": "Trust-focused design" } }
      ]
    }
  ]
}
{% endschema %}
