{% liquid
  assign primary_link = section.settings.primary_link | default: routes.all_products_collection_url
  assign secondary_link = section.settings.secondary_link | default: '/#contact-us'
  assign primary_label = section.settings.primary_label | strip | default: 'Explore all products'
  assign secondary_label = section.settings.secondary_label | strip | default: 'Talk to support'
  assign external_media_image_url = section.settings.external_media_image_url | strip | default: 'https://picsum.photos/seed/product-highlight/1400/900'
%}

<section class="section-shell">
  <div class="section-card section-pad split-panel split-panel--compact">
    <div class="split-panel__media">
      <div>
        <span class="kicker kicker--on-dark">{{ section.settings.kicker }}</span>
        <h2>{{ section.settings.media_heading }}</h2>
      </div>

      <a class="split-panel__media-image" href="{{ primary_link }}">
        {% if section.settings.media_image != blank %}
          {{ section.settings.media_image | image_url: width: 1400 | image_tag: loading: 'lazy', alt: section.settings.media_heading }}
        {% else %}
          <img src="{{ external_media_image_url | escape }}" alt="{{ section.settings.media_heading }}" loading="lazy" width="1400" height="900">
        {% endif %}
      </a>

      <ul>
        {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
            <li {{ block.shopify_attributes }}>{{ block.settings.point }}</li>
          {% endfor %}
        {% else %}
          <li>Clear variant and pricing hierarchy for quick decisions</li>
          <li>Fast-loading product cards with direct buying actions</li>
          <li>Trust and retention blocks before checkout drop-off</li>
          <li>Mobile-optimized spacing and CTA visibility</li>
        {% endif %}
      </ul>
    </div>

    <div class="split-panel__content">
      <div class="section-head">
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.description }}</p>
      </div>

      <div class="hero__actions">
        <a class="button button--primary" href="{{ primary_link }}">{{ primary_label }}</a>
        <a class="button button--ghost" href="{{ secondary_link }}">{{ secondary_label }}</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product highlights",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Why shoppers convert"
    },
    {
      "type": "text",
      "id": "media_heading",
      "label": "Media heading",
      "default": "Retail clarity for modern buyers"
    },
    {
      "type": "image_picker",
      "id": "media_image",
      "label": "Media image (optional)"
    },
    {
      "type": "text",
      "id": "external_media_image_url",
      "label": "External media image URL (fallback)",
      "default": "https://picsum.photos/seed/product-highlight/1400/900"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Make buying decisions easy"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Use product storytelling, comparison value, and trust cues to reduce hesitation and improve add-to-cart rate."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Explore all products"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Talk to support"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Point",
      "settings": [
        {
          "type": "text",
          "id": "point",
          "label": "Point",
          "default": "Highlight point"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Product highlights",
      "blocks": [
        { "type": "point", "settings": { "point": "Clear variant and pricing hierarchy" } },
        { "type": "point", "settings": { "point": "Fast-loading product cards with direct actions" } },
        { "type": "point", "settings": { "point": "Trust and retention blocks before checkout" } },
        { "type": "point", "settings": { "point": "Responsive spacing optimized for mobile shoppers" } }
      ]
    }
  ]
}
{% endschema %}
