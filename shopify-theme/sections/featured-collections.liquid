<section class="section-shell" id="catalog-overview">
  <div class="section-card section-pad">
    <div class="section-head">
      <span class="kicker">{{ section.settings.kicker }}</span>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.description }}</p>
    </div>

    <div class="collection-grid">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          {% liquid
            assign target_collection = collections[block.settings.collection]
            assign destination_url = block.settings.custom_link
            if destination_url == blank
              if target_collection
                assign destination_url = target_collection.url
              else
                assign destination_url = routes.collections_url
              endif
            endif

            assign cta_label = block.settings.cta_label | strip | default: 'View collection'

            assign card_title = block.settings.custom_title | strip
            if card_title == blank and target_collection
              assign card_title = target_collection.title
            endif
            if card_title == blank
              assign card_title = 'Collection title'
            endif

            assign card_description = block.settings.custom_description | strip
            if card_description == blank and target_collection and target_collection.description != blank
              assign card_description = target_collection.description | strip_html | truncate: 100
            endif
            if card_description == blank
              assign card_description = 'Curate this card from Theme Editor and feature your highest-intent category.'
            endif

            assign external_image_url = block.settings.external_image_url | strip
            if external_image_url == blank
              assign external_image_url = 'https://picsum.photos/seed/collection-lifestyle/1200/800'
            endif
          %}

          <article class="collection-card" {{ block.shopify_attributes }}>
            <a class="collection-card__media" href="{{ destination_url }}">
              {% if block.settings.collection_image != blank %}
                {{ block.settings.collection_image | image_url: width: 960 | image_tag: loading: 'lazy', alt: card_title }}
              {% elsif target_collection and target_collection.featured_image %}
                {{ target_collection.featured_image | image_url: width: 960 | image_tag: loading: 'lazy', alt: card_title }}
              {% else %}
                <img src="{{ external_image_url | escape }}" alt="{{ card_title }}" loading="lazy" width="960" height="600">
              {% endif %}
            </a>
            <div class="collection-card__body">
              <h3>{{ card_title }}</h3>
              <p>{{ card_description }}</p>
              <a class="button button--ghost" href="{{ destination_url }}">{{ cta_label }}</a>
            </div>
          </article>
        {% endfor %}
      {% else %}
        {% for i in (1..4) %}
          <article class="collection-card">
            <div class="collection-card__media">
              <img src="https://picsum.photos/seed/collection-{{ i }}/1200/800" alt="Collection {{ i }}" loading="lazy" width="960" height="600">
            </div>
            <div class="collection-card__body">
              <h3>Collection {{ i }}</h3>
              <p>Add featured collections in Theme Editor to replace these placeholders.</p>
              <a class="button button--ghost" href="{{ routes.collections_url }}">View collection</a>
            </div>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collections",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Shop by intent"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Curated collections crafted for different customer journeys"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Lead visitors from discovery to checkout with purposeful collection groupings that make browsing faster and decisions easier."
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Choose collection"
        },
        {
          "type": "image_picker",
          "id": "collection_image",
          "label": "Custom card image (optional)"
        },
        {
          "type": "text",
          "id": "external_image_url",
          "label": "External image URL (fallback)",
          "default": "https://picsum.photos/seed/collection-lifestyle/1200/800"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom title (optional)"
        },
        {
          "type": "textarea",
          "id": "custom_description",
          "label": "Custom description (optional)"
        },
        {
          "type": "url",
          "id": "custom_link",
          "label": "Custom link (optional)"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Button label",
          "default": "View collection"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Featured collections"
    }
  ]
}
{% endschema %}
